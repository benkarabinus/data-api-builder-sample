{
  "_comment": "Schema of the outputs.json that deploy.ps1 writes at the repo root. The real file is gitignored because it contains your subscription ID, UAMI IDs, and resource FQDNs. Values below are placeholders.",
  "deployedAtUtc": "2026-01-01T00:00:00.0000000Z",
  "resourceGroup": "rg-<namePrefix>-<env>",
  "location": "westus",
  "namePrefix": "<namePrefix>",
  "environmentName": "<env>",
  "subscriptionId": "<SUBSCRIPTION_ID>",
  "tenantId": "<TENANT_ID>",
  "uamiName": "<namePrefix>-uami-<env>",
  "uamiResourceId": "/subscriptions/<SUBSCRIPTION_ID>/resourceGroups/rg-<namePrefix>-<env>/providers/Microsoft.ManagedIdentity/userAssignedIdentities/<namePrefix>-uami-<env>",
  "uamiClientId": "<UAMI_CLIENT_GUID>",
  "uamiPrincipalId": "<UAMI_PRINCIPAL_GUID>",
  "sqlServerName": "<namePrefix>-sql-<env>-<uniq>",
  "sqlServerFqdn": "<namePrefix>-sql-<env>-<uniq>.database.windows.net",
  "sqlDatabaseName": "ProductsDB",
  "foundryAccountName": "<namePrefix>-ai-<env>-<uniq>",
  "foundryProjectName": "<namePrefix>-proj-<env>",
  "foundryEndpoint": "https://<namePrefix>-ai-<env>-<uniq>.services.ai.azure.com/api/projects/<namePrefix>-proj-<env>",
  "openAiEndpoint": "https://<namePrefix>-ai-<env>-<uniq>.openai.azure.com/",
  "embeddingDeployment": "embedding",
  "acrName": "<namePrefix>acr<env><uniq>",
  "acrLoginServer": "<namePrefix>acr<env><uniq>.azurecr.io",
  "dabImage": "<namePrefix>acr<env><uniq>.azurecr.io/dab:latest",
  "acaEnvName": "<namePrefix>-acaenv-<env>",
  "dabAppName": "<namePrefix>-dab-<env>",
  "dabAppFqdn": "<namePrefix>-dab-<env>.<random>.<region>.azurecontainerapps.io",
  "dabAppUrl": "https://<namePrefix>-dab-<env>.<random>.<region>.azurecontainerapps.io",
  "webAppName": "<namePrefix>-web-<env>",
  "webAppUrl": "https://<namePrefix>-web-<env>.<random>.<region>.azurecontainerapps.io"
}
