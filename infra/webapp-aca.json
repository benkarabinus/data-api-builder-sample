{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.43.8.12551",
      "templateHash": "2965654164473331567"
    }
  },
  "parameters": {
    "namePrefix": {
      "type": "string",
      "minLength": 3,
      "maxLength": 12,
      "metadata": {
        "description": "Name prefix used for all resources. Should match the foundation deploy."
      }
    },
    "environmentName": {
      "type": "string",
      "defaultValue": "dev",
      "minLength": 2,
      "maxLength": 6,
      "metadata": {
        "description": "Environment short name. Should match the foundation deploy."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for all resources."
      }
    },
    "uamiResourceId": {
      "type": "string",
      "metadata": {
        "description": "Resource ID of the User-Assigned Managed Identity (used to pull the image)."
      }
    },
    "acrName": {
      "type": "string",
      "metadata": {
        "description": "Name of the Azure Container Registry holding the web image."
      }
    },
    "webImage": {
      "type": "string",
      "metadata": {
        "description": "Full web image name including registry and tag, e.g. myregistry.azurecr.io/web:latest."
      }
    },
    "dabBaseUrl": {
      "type": "string",
      "metadata": {
        "description": "Public base URL of the hosted DAB app, e.g. https://sqlrag-dab-dev.<region>.azurecontainerapps.io."
      }
    },
    "foundryProjectEndpoint": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional: Foundry project endpoint for the agent chat tab, e.g. https://<account>.services.ai.azure.com/api/projects/<project>."
      }
    },
    "foundryAgentName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional: Foundry prompt agent name for the chat tab."
      }
    },
    "foundryAgentVersion": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional: Foundry prompt agent version for the chat tab. Empty resolves to the latest version."
      }
    },
    "uamiClientId": {
      "type": "string",
      "metadata": {
        "description": "Client ID of the User-Assigned Managed Identity. Required so DefaultAzureCredential targets the UAMI for agent calls."
      }
    }
  },
  "variables": {
    "acaEnvName": "[format('{0}-acaenv-{1}', parameters('namePrefix'), parameters('environmentName'))]",
    "webAppName": "[format('{0}-web-{1}', parameters('namePrefix'), parameters('environmentName'))]"
  },
  "resources": [
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2024-03-01",
      "name": "[variables('webAppName')]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "UserAssigned",
        "userAssignedIdentities": {
          "[format('{0}', parameters('uamiResourceId'))]": {}
        }
      },
      "properties": {
        "managedEnvironmentId": "[resourceId('Microsoft.App/managedEnvironments', variables('acaEnvName'))]",
        "configuration": {
          "ingress": {
            "external": true,
            "targetPort": 8501,
            "transport": "auto",
            "allowInsecure": false
          },
          "registries": [
            {
              "server": "[reference(resourceId('Microsoft.ContainerRegistry/registries', parameters('acrName')), '2023-11-01-preview').loginServer]",
              "identity": "[parameters('uamiResourceId')]"
            }
          ]
        },
        "template": {
          "containers": [
            {
              "name": "web",
              "image": "[parameters('webImage')]",
              "resources": {
                "cpu": "[json('0.5')]",
                "memory": "1Gi"
              },
              "env": [
                {
                  "name": "DAB_BASE_URL",
                  "value": "[parameters('dabBaseUrl')]"
                },
                {
                  "name": "AZURE_CLIENT_ID",
                  "value": "[parameters('uamiClientId')]"
                },
                {
                  "name": "FOUNDRY_PROJECT_ENDPOINT",
                  "value": "[parameters('foundryProjectEndpoint')]"
                },
                {
                  "name": "FOUNDRY_AGENT_NAME",
                  "value": "[parameters('foundryAgentName')]"
                },
                {
                  "name": "FOUNDRY_AGENT_VERSION",
                  "value": "[parameters('foundryAgentVersion')]"
                }
              ]
            }
          ],
          "scale": {
            "minReplicas": 1,
            "maxReplicas": 2
          }
        }
      }
    }
  ],
  "outputs": {
    "acaAppName": {
      "type": "string",
      "value": "[variables('webAppName')]"
    },
    "acaAppFqdn": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.App/containerApps', variables('webAppName')), '2024-03-01').configuration.ingress.fqdn]"
    },
    "acaAppUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.App/containerApps', variables('webAppName')), '2024-03-01').configuration.ingress.fqdn)]"
    }
  }
}